CREATE DATABASE hotel;

USE hotel;

CREATE TABLE bookings (
    id INT AUTO_INCREMENT PRIMARY KEY,
    customer_name VARCHAR(100),
    phone VARCHAR(15),
    room_no INT,
    room_type VARCHAR(20),
    days INT,
    total_amount DECIMAL(10,2)
);
import mysql.connector

# Connect to MySQL
db = mysql.connector.connect(
    host="localhost",
    user="root",
    password="your_password",
    database="hotel"
)

cursor = db.cursor()


ROOM_PRICE = {
    "Single": 1000,
    "Double": 1800,
    "Deluxe": 3000
}


def book_room():
    name = input("Customer Name: ")
    phone = input("Phone Number: ")
    room_no = int(input("Room Number: "))
    room_type = input("Room Type (Single/Double/Deluxe): ")

    if room_type not in ROOM_PRICE:
        print("Invalid room type!")
        return

    days = int(input("Number of Days: "))
    total = ROOM_PRICE[room_type] * days

    sql = """
    INSERT INTO bookings
    (customer_name, phone, room_no, room_type, days, total_amount)
    VALUES (%s,%s,%s,%s,%s,%s)
    """

    values = (name, phone, room_no, room_type, days, total)

    cursor.execute(sql, values)
    db.commit()

    print("Room Booked Successfully!")
    print("Total Amount =", total)


def view_bookings():
    cursor.execute("SELECT * FROM bookings")
    data = cursor.fetchall()

    print("\nBookings")
    print("-" * 70)

    for row in data:
        print(row)


def check_room():
    room = int(input("Enter Room Number: "))

    cursor.execute(
        "SELECT * FROM bookings WHERE room_no=%s",
        (room,)
    )

    data = cursor.fetchone()

    if data:
        print("Room is Occupied")
        print(data)
    else:
        print("Room is Available")


def cancel_booking():
    room = int(input("Enter Room Number to Cancel: "))

    cursor.execute(
        "DELETE FROM bookings WHERE room_no=%s",
        (room,)
    )

    db.commit()
    print("Booking Cancelled")


while True:

    print("\n===== HOTEL MANAGEMENT SYSTEM =====")
    print("1. Book Room")
    print("2. View Bookings")
    print("3. Check Room Availability")
    print("4. Cancel Booking")
    print("5. Exit")

    choice = input("Enter Choice: ")

    if choice == "1":
        book_room()

    elif choice == "2":
        view_bookings()

    elif choice == "3":
        check_room()

    elif choice == "4":
        cancel_booking()

    elif choice == "5":
        break

    else:
        print("Invalid Choice!")

cursor.close()
db.close()
